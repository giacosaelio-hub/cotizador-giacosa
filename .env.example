# Variables de entorno para desarrollo local
# Copiá este archivo a .env y completá los valores reales.
# .env está en .gitignore — nunca se commitea.
#
# En producción (EasyPanel), estas variables se configuran en el panel de entorno.

# Contraseña del panel de administración de precios.
# Es una variable del SERVIDOR (Express), no de Vite.
# No usar prefijo VITE_ — no debe quedar expuesta al cliente.
ADMIN_PASSWORD=tu_contraseña_aqui

# Nota: después de crear/modificar .env, reiniciá el servidor local:
#   npm run dev:server
